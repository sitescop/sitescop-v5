# Database
DATABASE_URL=postgresql://sitescop:sitescop_dev@localhost:5433/sitescop_v5

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Auth
SESSION_SECRET=change-this-to-a-long-random-string-in-production
SESSION_COOKIE_NAME=sitescop_session
SESSION_MAX_AGE_MS=604800000
PASSWORD_RESET_EXPIRY_MS=3600000
WEB_APP_URL=http://localhost:5173

# Web (Vite)
VITE_API_URL=http://localhost:3001

# Email (SMTP) — Zoho Mail for info@sitescop.com.au
#
# 1. In Zoho: Mail → Settings → Mail Accounts → Server Configuration (confirm SMTP host)
# 2. Create App Password: https://accounts.zoho.com → Security → App Passwords
#    (Enable 2FA first if you don't see App Passwords)
# 3. Paste the app password into SMTP_PASS below — NOT your normal login password
#
# Australia — business/custom domain (sitescop.com.au):
SMTP_HOST=smtppro.zoho.com.au
# Australia — free Zoho Mail (if the above fails, try this instead):
# SMTP_HOST=smtp.zoho.com.au
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@sitescop.com.au
SMTP_PASS=
#
# Alternative SSL port:
# SMTP_PORT=465
# SMTP_SECURE=true
#
# Local dev only (Mailpit): docker compose up mailpit -d → http://localhost:8025
# SMTP_HOST=localhost
# SMTP_PORT=1025
#
# Stripe (optional — client portal online payments)
# Create keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Twilio SMS (optional — Phase 8 client/inspector reminders)
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
