# SiteScop V5 — production Docker Compose
# Copy to .env.production and fill in values, then: npm run go-live

# Public domain (HTTPS via Caddy). Example: app.sitescop.com.au
APP_DOMAIN=app.sitescop.com.au

# Let's Encrypt notifications (optional)
CADDY_EMAIL=info@sitescop.com.au

# PostgreSQL (auto-created by compose — use a strong password)
POSTGRES_USER=sitescop
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Auth — generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS

# Must match https://APP_DOMAIN
WEB_APP_URL=https://app.sitescop.com.au

# Email (Zoho recommended for sitescop.com.au)
SMTP_HOST=smtppro.zoho.com.au
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@sitescop.com.au
SMTP_PASS=

# Optional — client portal card payments (live keys for production)
STRIPE_SECRET_KEY=

# Optional — SMS reminders
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# First admin user (run once after deploy: npm run db:seed:prod)
PROD_COMPANY_NAME=SiteScop Inspections
PROD_COMPANY_SLUG=sitescop
PROD_ADMIN_EMAIL=admin@sitescop.com.au
PROD_ADMIN_PASSWORD=CHANGE_ME_BEFORE_FIRST_LOGIN
