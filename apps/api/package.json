{
  "name": "@sitescop/api",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed-production.ts",
    "db:sync-branding": "node scripts/sync-company-branding.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.8.2",
    "@sitescop/report-pdf": "*",
    "@sitescop/room-engine-core": "*",
    "@sitescop/shared-types": "*",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "nodemailer": "^7.0.3",
    "stripe": "^17.7.0",
    "twilio": "^5.13.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@sitescop/eslint-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.27.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
