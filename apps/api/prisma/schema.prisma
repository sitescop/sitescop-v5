generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  OFFICE_MANAGER
  OFFICE_STAFF
  INSPECTOR
  ACCOUNTANT
  CLIENT
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DEACTIVATED
}

enum JobStatus {
  DRAFT
  PENDING_ASSIGNMENT
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum JobType {
  BUILDING
  PEST
  COMBINED
  PRE_PURCHASE
  PRE_SALE
  OTHER
}

enum JobContractSource {
  DIGITAL
  MANUAL_PAPER
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ContactType {
  CLIENT
  AGENT
  BUILDER
  PROPERTY_MANAGER
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

enum AgreementStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
  CANCELLED
}

enum InspectionStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum InspectionRoomType {
  BEDROOM
  BATHROOM
  LIVING
  GARAGE
}

enum ReportType {
  BUILDING
  PEST
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHEQUE
  OTHER
}

enum NotificationType {
  JOB_CREATED
  JOB_ASSIGNED
  JOB_COMPLETED
  AGREEMENT_SENT
  AGREEMENT_SIGNED
  AGREEMENT_DECLINED
  INVOICE_SENT
  INVOICE_PAID
  PAYMENT_RECEIVED
  SYSTEM
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  abn       String?
  email     String?
  phone     String?
  website   String?
  address   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  auditLogs AuditLog[]
  contacts  Contact[]
  properties Property[]
  jobs        Job[]
  agreements  Agreement[]
  inspections Inspection[]
  inspectionReports InspectionReport[]
  invoices    Invoice[]
  notifications Notification[]
  emailMessages EmailMessage[]
  smsMessages   SmsMessage[]
  settings    CompanySettings?
  apiKeys     ApiKey[]

  @@map("companies")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     UserSession[]
  passwordResetTokens PasswordResetToken[]
  auditLogs    AuditLog[] @relation("AuditActor")
  createdJobs  Job[]      @relation("JobCreator")
  assignedJobs Job[]      @relation("JobInspector")
  jobAssignments JobAssignment[] @relation("AssignmentInspector")
  assignmentsMade JobAssignment[] @relation("AssignmentAssigner")
  createdAgreements Agreement[] @relation("AgreementCreator")
  inspections       Inspection[] @relation("InspectionInspector")
  createdInspections Inspection[] @relation("InspectionCreator")
  generatedReports   InspectionReport[] @relation("ReportGenerator")
  createdInvoices    Invoice[]          @relation("InvoiceCreator")
  notifications      Notification[]

  @@index([companyId])
  @@index([role])
  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Contact {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        ContactType
  status      ContactStatus @default(ACTIVE)
  firstName   String
  lastName    String
  email       String?
  phone       String?
  companyName String?
  abn         String?
  address     String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  clientJobs  Job[]         @relation("JobClient")
  agentJobs   Job[]         @relation("JobAgent")
  agreements  Agreement[]
  invoices    Invoice[]

  @@index([companyId])
  @@index([type])
  @@index([deletedAt])
  @@map("contacts")
}

model Property {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addressLine1 String
  addressLine2 String?
  suburb       String
  state        String
  postcode     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]

  @@index([companyId])
  @@map("properties")
}

model Job {
  id                   String     @id @default(cuid())
  companyId            String
  company              Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobNumber            String
  title                String
  description          String?
  type                 JobType            @default(BUILDING)
  contractSource       JobContractSource  @default(DIGITAL)
  status               JobStatus          @default(DRAFT)
  propertyId           String?
  property             Property?  @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  clientContactId      String?
  clientContact        Contact?   @relation("JobClient", fields: [clientContactId], references: [id], onDelete: SetNull)
  agentContactId       String?
  agentContact         Contact?   @relation("JobAgent", fields: [agentContactId], references: [id], onDelete: SetNull)
  scheduledDate        DateTime?
  scheduledTime        String?
  priceCents           Int?
  notes                String?
  assignedInspectorId  String?
  assignedInspector    User?      @relation("JobInspector", fields: [assignedInspectorId], references: [id], onDelete: SetNull)
  createdById          String
  createdBy            User       @relation("JobCreator", fields: [createdById], references: [id])
  assignments          JobAssignment[]
  agreements           Agreement[]
  inspections          Inspection[]
  invoices             Invoice[]
  completedAt          DateTime?
  cancelledAt          DateTime?
  archivedAt           DateTime?
  deletedAt            DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@unique([companyId, jobNumber])
  @@index([companyId])
  @@index([status])
  @@index([assignedInspectorId])
  @@index([deletedAt])
  @@index([archivedAt])
  @@map("jobs")
}

model JobAssignment {
  id             String           @id @default(cuid())
  jobId          String
  job            Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspectorId    String
  inspector      User             @relation("AssignmentInspector", fields: [inspectorId], references: [id])
  assignedById   String
  assignedBy     User             @relation("AssignmentAssigner", fields: [assignedById], references: [id])
  status         AssignmentStatus @default(PENDING)
  declineReason  String?
  respondedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([jobId])
  @@index([inspectorId])
  @@map("job_assignments")
}

model CompanySettings {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  primaryColor          String   @default("#0B6E4F")
  secondaryColor        String   @default("#1E3A5F")
  reportHeader          String?
  reportFooter          String?
  emailFromName         String?
  emailFromAddress      String?
  emailSignature        String?
  smsEnabled            Boolean  @default(false)
  smsSenderId           String?
  pdfFooterText         String?
  pdfIncludeLogo        Boolean  @default(true)
  notifyNewJob          Boolean  @default(true)
  notifyJobAssigned     Boolean  @default(true)
  notifyJobCompleted    Boolean  @default(true)
  defaultBuildingPrice  Int?
  defaultPestPrice      Int?
  defaultCombinedPrice  Int?
  gstRate               Float    @default(10)
  emailTemplates        Json     @default("{}")
  smsTemplates          Json     @default("{}")
  integrations          Json     @default("{}")
  agreementTemplates    Json     @default("{}")
  backupEnabled         Boolean  @default(false)
  backupFrequency       String   @default("weekly")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("company_settings")
}

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String
  keyHash    String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId])
  @@map("api_keys")
}

model Agreement {
  id                    String          @id @default(cuid())
  companyId             String
  company               Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agreementNumber       String
  jobId                 String?
  job                   Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  status                AgreementStatus @default(DRAFT)
  type                  JobType         @default(BUILDING)
  clientContactId       String?
  clientContact         Contact?        @relation(fields: [clientContactId], references: [id], onDelete: SetNull)
  clientName            String
  clientEmail           String
  clientPhone           String?
  propertyAddress       String
  priceCents            Int             @default(0)
  gstCents              Int             @default(0)
  totalCents            Int             @default(0)
  agreementDate         DateTime        @default(now())
  notes                 String?
  legalSections         Json            @default("{}")
  accessTokenHash       String?         @unique
  accessTokenExpiresAt  DateTime?
  sentAt                DateTime?
  viewedAt              DateTime?
  signedAt              DateTime?
  declinedAt            DateTime?
  cancelledAt           DateTime?
  expiresAt             DateTime?
  declineReason         String?
  signatureName         String?
  signatureData         String?
  signedIp              String?
  declarationsAccepted  Boolean         @default(false)
  createdById           String
  createdBy             User            @relation("AgreementCreator", fields: [createdById], references: [id])
  invoices              Invoice[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([companyId, agreementNumber])
  @@index([companyId])
  @@index([status])
  @@index([jobId])
  @@index([clientEmail])
  @@map("agreements")
}

model Invoice {
  id               String         @id @default(cuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNumber    String
  status           InvoiceStatus  @default(DRAFT)
  jobId            String?
  job              Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  agreementId      String?
  agreement        Agreement?     @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  clientContactId  String?
  clientContact    Contact?       @relation(fields: [clientContactId], references: [id], onDelete: SetNull)
  clientName       String
  clientEmail      String
  propertyAddress  String?
  description      String
  subtotalCents    Int
  gstCents         Int
  totalCents       Int
  issueDate        DateTime       @default(now())
  dueDate          DateTime?
  sentAt           DateTime?
  paidAt           DateTime?
  paymentMethod    PaymentMethod?
  paymentReference String?
  notes            String?
  createdById      String
  createdBy        User           @relation("InvoiceCreator", fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([status])
  @@index([jobId])
  @@index([agreementId])
  @@map("invoices")
}

model Notification {
  id         String           @id @default(cuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@index([companyId])
  @@index([createdAt])
  @@map("notifications")
}

model EmailMessage {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  toEmail      String
  subject      String
  templateKey  String?
  status       EmailDeliveryStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("email_messages")
}

model SmsMessage {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  toPhone      String
  templateKey  String?
  status       EmailDeliveryStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("sms_messages")
}

model Inspection {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inspectionNumber String
  jobId            String
  job              Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status           InspectionStatus @default(DRAFT)
  inspectorId      String?
  inspector        User?            @relation("InspectionInspector", fields: [inspectorId], references: [id], onDelete: SetNull)
  formData         Json             @default("{}")
  progressPercent  Int              @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdById      String
  createdBy        User             @relation("InspectionCreator", fields: [createdById], references: [id])
  rooms            InspectionRoom[]
  reports          InspectionReport[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([companyId, inspectionNumber])
  @@index([companyId])
  @@index([jobId])
  @@index([status])
  @@index([inspectorId])
  @@map("inspections")
}

model InspectionReport {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inspectionId  String
  inspection    Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  reportType    ReportType
  status        ReportStatus @default(GENERATING)
  fileName      String
  filePath      String?
  fileSizeBytes Int?
  errorMessage  String?
  generatedById String
  generatedBy   User         @relation("ReportGenerator", fields: [generatedById], references: [id])
  generatedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([inspectionId, reportType])
  @@index([companyId])
  @@index([inspectionId])
  @@index([status])
  @@map("inspection_reports")
}

model InspectionRoom {
  id           String             @id @default(cuid())
  inspectionId String
  inspection   Inspection         @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  roomType     InspectionRoomType
  roomIndex    Int
  label        String
  data         Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([inspectionId, roomType, roomIndex])
  @@index([inspectionId])
  @@map("inspection_rooms")
}
